include CHANGELOG.md
include LICENSE
include README.md
include pyproject.toml
recursive-include documents *.md
recursive-include spec *.md
recursive-include protocols *.md
recursive-include templates *.template
recursive-include skills *.md *.template
recursive-include wrappers *.md
recursive-include docs *.md
recursive-include examples *.md
recursive-include evals *.md
recursive-include tests *.py
recursive-include tools *.py
prune .github
prune working-ledger
prune build
prune dist
prune *.egg-info
global-exclude __pycache__/*
global-exclude *.py[cod]
